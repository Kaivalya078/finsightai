# FinSightAI - Root .gitignore

# Environment variables
.env
*.env
!.env.example

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
venv/
env/
.venv/
.pytest_cache/

# Node
node_modules/
dist/
dist-ssr/
*.local

# IDEs
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Build artifacts
build/
*.egg-info/

# Vector database / FAISS
*.index
*.faiss

# Cache
.cache/

# === FinSight-specific ===

# FAISS index + corpus cache (generated by batch_ingest)
index_cache/

# Source PDFs (too large for Git)
backend/data/

# Session upload temp files
backend/temp_data/

# Serialized corpus data
*.pkl

# Test artifacts
backend/test_run1.json
