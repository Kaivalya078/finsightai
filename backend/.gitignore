# FinSight AI - Git Ignore

# Virtual environment
venv/
env/
.venv/

# Environment variables (contains secrets)
.env

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Jupyter Notebook
.ipynb_checkpoints

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# FAISS index files (if we persist them later)
*.index
*.faiss

# Model cache (large files)
# Note: sentence-transformers caches in ~/.cache/huggingface/
