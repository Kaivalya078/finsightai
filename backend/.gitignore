# FinSight AI - Backend .gitignore

# Virtual environment
venv/
env/
.venv/

# Environment variables (contains secrets)
.env

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Jupyter Notebook
.ipynb_checkpoints

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# === FinSight-specific ===

# FAISS index + corpus cache (generated by batch_ingest)
index_cache/

# Source PDFs (too large for Git — document setup in README)
data/

# Session upload temp files
temp_data/

# Serialized corpus data
*.pkl

# Test artifacts
test_run1.json
.pytest_cache/

# Model cache (sentence-transformers caches in ~/.cache/huggingface/)
