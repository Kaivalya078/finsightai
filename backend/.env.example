# FinSight AI - Environment Configuration (Stage 8)
# Copy this file to .env and fill in values

# Embedding model name (uses sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Chunk settings (Stage 8: optimized for financial table coherence)
CHUNK_SIZE=900
CHUNK_OVERLAP=150

# Retrieval settings
TOP_K=5

# OpenAI Generation
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# Index persistence
INDEX_CACHE_DIR=index_cache

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=finsightai

# JWT Authentication
JWT_SECRET=change-me-to-a-strong-random-secret
