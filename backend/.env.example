# FinSight AI - Environment Configuration (Phase 1: Core Retrieval Fixes)
# Copy this file to .env and fill in values

# Embedding model name (uses sentence-transformers)
# BAAI/bge-base-en-v1.5: 768-dim, instruction-based asymmetric retrieval
# Alternatives: bge-large-en-v1.5 (1024-dim, slower), e5-base-v2, all-MiniLM-L6-v2 (legacy)
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# Chunk settings (optimized for financial table coherence)
# Larger chunks preserve context; 20% overlap prevents sentence boundary loss
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Retrieval settings
TOP_K=5

# Similarity score threshold (cosine similarity, 0-1)
# Chunks below this score are filtered out before reaching the LLM.
# Start conservative at 0.30; tune upward after analyzing score distributions.
SIMILARITY_THRESHOLD=0.30

# Query instruction prefix for BGE asymmetric retrieval
# Applied to queries only, NOT to document chunks during indexing.
QUERY_INSTRUCTION=Represent this sentence for searching relevant passages:

# OpenAI Generation
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# Index persistence
INDEX_CACHE_DIR=index_cache
