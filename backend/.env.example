# FinSight AI - Environment Configuration
# Copy this file to .env and fill in values

# Path to your PDF file (relative to backend/ folder)
PDF_PATH=data/sample.pdf

# Embedding model name (uses sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Chunk settings
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Retrieval settings
TOP_K=5

# Phase 2: OpenAI Generation
OPENAI_API_KEY=your-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Phase 2.5: Default document metadata
DEFAULT_COMPANY=demo_company
DEFAULT_DOC_TYPE=DRHP
DEFAULT_YEAR=2024
